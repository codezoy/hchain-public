# HCHAIN Environment Configuration Example
# Copy this file to .env and fill in values as needed.
# This project (HCHAIN Core) requires no external API keys by default.
# The following variables are optional overrides for advanced use.

# --- API Health Check ---
# Internal API server for harness validation health checks.
# Default: http://<TAILSCALE_IP>:8801 (Tailscale internal; override for other environments)
# HARNESS_API_HEALTH_URL=http://localhost:8801

# --- Harness Behavior ---
# Set to 1 to skip interactive confirmation prompts
# HARNESS_AUTO_CONFIRM=0

# --- Timeout Settings (seconds) ---
# VALIDATE_TIMEOUT_DEFAULT=60
# CODEX_TIMEOUT=120
# GEMINI_TIMEOUT=60
