# --- hchain runtime (installed into target projects, never Core itself) ---
.hchain/

# --- environment & secrets ---
.env
.env.*
*.env
!.env.example

# --- runtime state files ---
active_state.json
*.state.json
*.checkpoint.json

# --- logs & reports ---
logs/
reports/
*.log

# --- queue & runtime task state ---
queue/
TASK_*.json

# --- harness runtime directories (auto-generated by harness_runner.sh; belong in target projects, not Core) ---
harness/findings/
harness/missions/
harness/tasks/

# --- Python ---
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# --- certificates & keys ---
*.pem
*.key
*.crt
*.p12
id_rsa*
id_ed25519*

# --- database files ---
*.db
*.sqlite
*.sqlite3

# --- node / frontend ---
node_modules/

# --- test cache ---
.pytest_cache/

# --- OS & IDE ---
.DS_Store
.vscode/
.idea/
*.swp
*.swo
Thumbs.db

# --- ensure docs/tasks/ task documents ARE tracked ---
!docs/tasks/
!docs/tasks/*.md
docs/prompts/

# --- personal retrospective (private writing) ---
docs/retrospective/
